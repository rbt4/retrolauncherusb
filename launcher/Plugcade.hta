<!DOCTYPE html>
<html>
<head>
<title>Plugcade</title>
<HTA:APPLICATION ID="plugcade" APPLICATIONNAME="Plugcade" VERSION="0.4.0" BORDER="thick" CAPTION="yes" SHOWINTASKBAR="yes" SINGLEINSTANCE="yes" SCROLL="yes" WINDOWSTATE="normal" />
<meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
<meta http-equiv="X-UA-Compatible" content="IE=8" />
<style type="text/css">
html,body{margin:0;padding:0;background:#fff4df;color:#211a37;font-family:Verdana,Arial,sans-serif;font-size:13px}button,input,select{font-family:Verdana,Arial,sans-serif}.top{background:#fffaf0;border-bottom:4px solid #211a37;padding:12px 18px;min-height:46px}.logo{float:left;font-family:Courier New,monospace;font-weight:bold;font-size:25px;color:#ff522e;letter-spacing:-2px}.tag{float:left;margin:8px 0 0 14px;font-size:10px;font-weight:bold;letter-spacing:1px}.status{float:right;margin:3px 0 0 8px;background:#dff5e6;border:2px solid #211a37;padding:7px 10px;font-weight:bold}.mode{float:right;background:#ffd13b;border:2px solid #211a37;padding:7px 10px;font-weight:bold;box-shadow:2px 2px 0 #211a37;cursor:pointer}.hero{background:#ff522e;color:#211a37;border-bottom:4px solid #211a37;padding:18px 22px}.hero h1{color:white;font-size:29px;margin:0 0 4px;text-shadow:3px 3px 0 #211a37}.hero b{color:#ffd13b}.hero p{margin:0;font-weight:bold}.kidGuide{display:none;background:#ffd13b;border-bottom:4px solid #211a37;padding:12px 20px;text-align:center;font-size:17px;font-weight:bold}.kidGuide span{display:inline-block;margin:3px 16px}.kidGuide i{display:inline-grid;width:32px;height:32px;line-height:32px;margin-right:6px;background:#fffaf0;border:2px solid #211a37;border-radius:50%;font-style:normal}.toolbar{padding:14px 18px 8px;overflow:hidden}.toolbar select,.action{border:2px solid #211a37;background:#fffaf0;padding:8px 10px;margin:0 7px 6px 0;font-weight:bold;box-shadow:3px 3px 0 #211a37}.action{cursor:pointer}.action.import{background:#38b86d}.action.systems{background:#35aef4}.search{padding:0 18px 10px}.search input{width:96%;border:3px solid #211a37;padding:9px;background:white;font-size:14px}.content{padding:0 14px 30px}.card{display:inline-block;vertical-align:top;width:215px;margin:8px;border:3px solid #211a37;background:#fffaf0;box-shadow:5px 5px 0 #211a37;cursor:pointer}.card.selected{outline:6px solid #ffd13b;outline-offset:2px}.cover{height:115px;border-bottom:3px solid #211a37;overflow:hidden;position:relative;text-align:center}.cover img{width:100%;height:100%;object-fit:cover}.cover .letter{display:block;padding-top:26px;font-family:Courier New,monospace;font-weight:bold;font-size:48px;color:#ffd13b;text-shadow:3px 3px 0 #211a37}.cover .plat{position:absolute;right:5px;top:5px;background:#211a37;color:white;padding:4px;font-size:9px}.info{padding:11px}.info h2{font-size:17px;margin:0 0 3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.info p{color:#746b80;margin:0 0 9px;height:16px}.cardButtons{white-space:nowrap}.play,.say,.help{border:2px solid #211a37;padding:8px;font-weight:bold;cursor:pointer}.play{width:100%;background:#ffd13b}.say,.help{display:none;width:48%;margin-top:6px;background:#35aef4}.help{background:#38b86d}.warning{background:#fff0bd;border:2px solid #211a37;padding:7px;margin-top:8px;font-size:10px}.empty{margin:25px;padding:25px;border:3px dashed #211a37;text-align:center}.empty .big{font-size:62px;color:#ff522e;font-family:Courier New,monospace;font-weight:bold}.panel{margin:12px 20px 25px;padding:17px;border:3px solid #211a37;background:#fffaf0;box-shadow:5px 5px 0 #211a37}.panel h2{margin-top:0}.row{padding:8px 0;border-bottom:1px solid #dfd1b7}.ok{color:#147a42;font-weight:bold}.bad{color:#c43d2f;font-weight:bold}.systemGrid{overflow:hidden}.systemItem{float:left;width:31%;min-height:48px;margin:5px;padding:7px;border:2px solid #211a37;background:#fff4df}.systemItem input{width:20px;height:20px;vertical-align:middle}.systemItem b{display:inline-block;vertical-align:middle}.panelButtons{clear:both;padding-top:13px}.overlay{display:none;position:fixed;left:0;right:0;top:0;bottom:0;background:#211a37;z-index:50}.helpbox{width:68%;max-height:70%;overflow:auto;margin:7% auto;padding:24px;background:#fffaf0;border:5px solid #211a37;box-shadow:10px 10px 0 #ff522e}.helpbox h2{font-size:27px;margin-top:0}.helpText{white-space:pre-wrap;font-size:17px;line-height:1.5}.close{background:#ffd13b;border:3px solid #211a37;padding:10px 18px;font-weight:bold}.foot{background:#211a37;color:white;padding:13px 20px;font-size:10px}.clear{clear:both}.hidden{display:none}.kid .adultOnly{display:none}.kid .kidGuide{display:block}.kid .card{width:260px;margin:13px}.kid .cover{height:165px}.kid .cover .letter{padding-top:46px;font-size:62px}.kid .info h2{font-size:23px;text-align:center}.kid .info p{text-align:center;font-size:12px}.kid .play{font-size:19px;padding:12px}.kid .say,.kid .help{display:inline-block;font-size:14px}.kid .warning{display:none}.kid .content{text-align:center}.kid .empty{font-size:17px}.kid .hero{padding:13px 22px}.kid .hero h1{font-size:24px}
.action.smart{background:#ffd13b}.kidGuide i{display:inline-block}.cover img{width:100%;height:100%}.setupLead{font-size:17px;font-weight:bold}.setupSteps{overflow:hidden;margin:12px 0}.setupStep{float:left;width:29%;min-height:105px;margin:5px;padding:12px;border:3px solid #211a37;background:#fff4df}.setupStep b{display:block;color:#ff522e;font-size:18px}.setupStep span{display:block;margin-top:5px;color:#665f70}.autoBox{clear:both;margin-top:14px;padding:12px;background:#fff0bd;border:2px solid #211a37}.autoBox label{display:inline-block;margin:5px 18px 5px 0;font-weight:bold}.miniStatus{display:inline-block;margin:4px 10px 4px 0;padding:6px 8px;background:#dff5e6;border:2px solid #211a37;font-weight:bold}.reportList{max-height:170px;overflow:auto;background:#211a37;color:white;padding:9px;font-family:Courier New,monospace;font-size:11px}
</style>
<script language="JScript">
var fso=new ActiveXObject("Scripting.FileSystemObject"),shell=new ActiveXObject("WScript.Shell");
var root="",current="ALL",kidMode=true,games=[],visibleGames=[],selected=0,enabled="",voice=null;
function P(id,name,exts,kind,symbol,color,aliases){return{id:id,name:name,exts:exts,kind:kind,symbol:symbol,color:color,aliases:aliases};}
var platforms=[
P("DOS","DOS","","dos","PC","#1677d2","DOSGAMES"),P("CD","DOS CD-ROM","cue,iso","doscd","CD","#6659a7","CDROM,DOSCD"),P("ARCADE","Arcade / MAME","zip","rom","A","#ed5a2a","MAME,ARCADEGAMES"),
P("NES","Nintendo NES","nes,fds","rom","N","#c43d2f","FAMICOM,NINTENDO"),P("SNES","Super Nintendo","sfc,smc","rom","S","#7464ba","SUPERFAMICOM,SUPERNES"),P("N64","Nintendo 64","z64,n64,v64","rom","64","#38b86d","NINTENDO64"),
P("GB","Game Boy","gb","rom","GB","#739b3b","GAMEBOY"),P("GBC","Game Boy Color","gbc","rom","C","#f65b9a","GAMEBOYCOLOR"),P("GBA","Game Boy Advance","gba","rom","G","#6659a7","GAMEBOYADVANCE"),P("VB","Virtual Boy","vb","rom","V","#d8362a","VIRTUALBOY"),
P("GENESIS","Genesis / Mega Drive","md,gen,smd,bin","rom","16","#211a37","MEGADRIVE,SEGA"),P("SMS","Master System","sms","rom","M","#35aef4","MASTERSYSTEM"),P("GAMEGEAR","Game Gear","gg","rom","GG","#1677d2","GEAR"),P("SEGA32X","Sega 32X","32x","rom","32","#211a37","32X"),P("SEGACD","Sega CD","cue,iso","disc","SC","#c43d2f","MEGACD"),
P("PS1","PlayStation 1","cue,iso,chd,ccd,mds","disc","PS","#6d6d6d","PLAYSTATION,PSX"),P("PCE","PC Engine / TurboGrafx","pce","rom","P","#ff522e","PCENGINE,TURBOGRAFX,TG16"),
P("ATARI2600","Atari 2600","a26,bin","rom","26","#f1b91d","2600,VCS"),P("ATARI7800","Atari 7800","a78,bin","rom","78","#ed5a2a","7800"),P("LYNX","Atari Lynx","lnx","rom","L","#35aef4","ATARILYNX"),
P("NGP","Neo Geo Pocket","ngp,ngc","rom","NG","#38b86d","NEOGEOPOCKET"),P("WONDERSWAN","WonderSwan","ws,wsc","rom","W","#7464ba","WS"),P("COLECO","ColecoVision","col,rom","rom","C","#1677d2","COLECOVISION"),P("INTELLIVISION","Intellivision","int,bin,rom","rom","I","#ed5a2a","INTV"),P("MSX","MSX","rom,mx1,mx2,dsk","rom","M","#38b86d","MSX1,MSX2"),P("AMIGA","Commodore Amiga","adf,adz,ipf,lha","rom","A","#f65b9a","COMMODOREAMIGA")
];
function esc(s){return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/\"/g,"&quot;");}
function q(s){return '"'+String(s).replace(/"/g,'""')+'"';}
function pathFromUrl(){var p=unescape(location.pathname);if(p.charAt(0)=="/"&&p.charAt(2)==":")p=p.substr(1);return fso.GetParentFolderName(p.replace(/\//g,"\\"));}
function ensure(p){if(!fso.FolderExists(p))fso.CreateFolder(p);}
function ext(n){var i=n.lastIndexOf(".");return i<0?"":n.substr(i+1).toLowerCase();}
function base(n){var i=n.lastIndexOf(".");return i<0?n:n.substr(0,i);}
function safeName(n){return n.replace(/[\\\/:*?\"<>|]/g,"_");}
function norm(n){return String(n).toUpperCase().replace(/[^A-Z0-9]/g,"");}
function platform(id){for(var i=0;i<platforms.length;i++)if(platforms[i].id==id)return platforms[i];return null;}
function contains(csv,v){return(","+csv.toUpperCase()+",").indexOf(","+v.toUpperCase()+",")>=0;}
function enabledPlatform(p){return contains(enabled,p.id);}
function settingsPath(){return root+"\\Config\\settings.ini";}
function readKey(path,key,def){if(!fso.FileExists(path))return def;var t=fso.OpenTextFile(path,1,false),line,k=key.toLowerCase()+"=";while(!t.AtEndOfStream){line=t.ReadLine();if(line.toLowerCase().indexOf(k)==0){t.Close();return line.substr(k.length);}}t.Close();return def;}
function writePlatformGuide(){var path=root+"\\Config\\PLATFORMS.txt";if(fso.FileExists(path))return;var t=fso.OpenTextFile(path,2,true);t.WriteLine("PLUGCADE PLATFORM FOLDERS");t.WriteLine("=========================");t.WriteLine("");for(var i=0;i<platforms.length;i++)t.WriteLine(platforms[i].id+" = "+platforms[i].name+" ["+platforms[i].exts+"]");t.WriteLine("");t.WriteLine("Enable or disable systems from Grown-up Mode > Choose systems.");t.Close();}
function exts(p){return p.exts?p.exts.split(","):[];}
function accepted(p,file){var z=ext(file.Name),a=exts(p);for(var i=0;i<a.length;i++)if(z==a[i])return true;return false;}
function firstFile(folder,p){var e=new Enumerator(folder.Files);for(;!e.atEnd();e.moveNext()){var x=e.item();if(accepted(p,x))return x.Path;}return "";}
function findDosTarget(folder){var bad=" setup install config uninstall unins patch update register readme help ",best="",count=0,e=new Enumerator(folder.Files);for(;!e.atEnd();e.moveNext()){var x=e.item(),z=ext(x.Name),n=" "+base(x.Name).toLowerCase()+" ";if((z=="exe"||z=="com"||z=="bat")&&bad.indexOf(n)<0){if(!best)best=x.Name;count++;}}return count==1?best:"";}
function coverFor(dir){var n=["cover.jpg","cover.png","cover.gif","cover.bmp"];for(var i=0;i<n.length;i++)if(fso.FileExists(dir+"\\"+n[i]))return dir+"\\"+n[i];return "";}
function fileUrl(p){return encodeURI("file:///"+p.replace(/\\/g,"/"));}
function buildFilter(){var s=document.getElementById("platformFilter"),h='<option value="ALL">ALL SYSTEMS</option>';for(var i=0;i<platforms.length;i++)if(enabledPlatform(platforms[i]))h+='<option value="'+platforms[i].id+'">'+esc(platforms[i].name)+'</option>';s.innerHTML=h;s.value=current;}
function cancelClick(){if(window.event)window.event.cancelBubble=true;}
function changeFilter(){current=document.getElementById("platformFilter").value;render();}
function speak(text){try{if(!voice)voice=new ActiveXObject("SAPI.SpVoice");voice.Speak(text,1);return true;}catch(e){return false;}}
function speakGame(i){var g=games[i],p=platform(g.platform);if(!speak("Play "+g.title+". "+p.name+"."))alert(g.title+"\n"+p.name+"\n\nSpeech is not installed on this Windows computer.");}
function helpGame(i){var g=games[i],path=g.dir+"\\help.txt",text="No help card has been added for this game yet. Ask a grown-up for help.";if(fso.FileExists(path)){var t=fso.OpenTextFile(path,1,false);text=t.ReadAll();t.Close();}document.getElementById("helpTitle").innerText=g.title+" - Help";document.getElementById("helpText").innerText=text;document.getElementById("overlay").style.display="block";speak(text.substr(0,700));}
function closeHelp(){document.getElementById("overlay").style.display="none";}
function token(s,key,value){while(s.indexOf(key)>=0)s=s.replace(key,value);return s;}
function matchFolder(name){var n=norm(name);for(var i=0;i<platforms.length;i++){var p=platforms[i];if(n==norm(p.id)||n==norm(p.name)||contains(p.aliases,n))return p;}return null;}
function togglePanel(id){var p=document.getElementById(id);p.className=p.className.indexOf("hidden")>=0?p.className.replace(" hidden",""):p.className+" hidden";}
function showSystems(){var h='<h2>Choose systems</h2><p>Enable only what this computer or USB needs. You can change this any time.</p><div class="systemGrid">';for(var i=0;i<platforms.length;i++){var p=platforms[i];h+='<label class="systemItem"><input type="checkbox" id="sys'+p.id+'" '+(enabledPlatform(p)?'checked="checked"':'')+' /> <b>'+esc(p.name)+'</b><br /><small>.'+esc(p.exts.replace(/,/g,", ."))+'</small></label>';}h+='</div><div class="panelButtons"><button class="action" onclick="systemPreset(\'classic\')">CLASSIC PICKS</button><button class="action" onclick="systemPreset(\'all\')">ENABLE ALL</button><button class="action import" onclick="saveSystems()">SAVE SYSTEMS</button></div>';document.getElementById("systemsPanel").innerHTML=h;document.getElementById("systemsPanel").className="panel";}
function systemPreset(which){var classic="DOS,CD,ARCADE,NES,SNES,N64,GB,GBC,GBA,GENESIS,SMS,GAMEGEAR,PCE,ATARI2600,PS1";for(var i=0;i<platforms.length;i++)document.getElementById("sys"+platforms[i].id).checked=which=="all"||contains(classic,platforms[i].id);}
function saveSystems(){var s="";for(var i=0;i<platforms.length;i++)if(document.getElementById("sys"+platforms[i].id).checked)s+=(s?",":"")+platforms[i].id;if(!s){alert("Choose at least one system.");return;}enabled=s;saveSettings();ensureTree();document.getElementById("systemsPanel").className="panel hidden";scan();}
function toggleMode(){kidMode=!kidMode;saveSettings();applyMode();render();diagnose();}
function applyMode(){document.body.className=kidMode?"kid":"grown";document.getElementById("modeButton").innerText=kidMode?"GROWN-UP MODE":"KID MODE";if(kidMode){current="ALL";document.getElementById("find").value="";}}
</script>
<script language="JScript">
/* Plugcade Core 0.4: tiny automation layer. Kept ES3/ActiveX-friendly for old Windows. */
var cfg={},firstRun=false,emuCache={},seenGames={},importStats=null;
var defaultPlatforms="DOS,CD,ARCADE,NES,SNES,N64,GB,GBC,GBA,GENESIS,SMS,GAMEGEAR,PCE,ATARI2600,PS1";
function pad2(n){return n<10?"0"+n:String(n);}
function dayKey(){var d=new Date();return d.getFullYear()+pad2(d.getMonth()+1)+pad2(d.getDate());}
function timeKey(){var d=new Date();return dayKey()+"_"+pad2(d.getHours())+pad2(d.getMinutes())+pad2(d.getSeconds());}
function readIni(path){var o={},t,line,pos;if(!fso.FileExists(path))return o;t=fso.OpenTextFile(path,1,false);while(!t.AtEndOfStream){line=t.ReadLine();if(line&&line.charAt(0)!=";"&&line.charAt(0)!="#"){pos=line.indexOf("=");if(pos>0)o[line.substr(0,pos).toLowerCase()]=line.substr(pos+1);}}t.Close();return o;}
function loadSettings(){var path=settingsPath();firstRun=!fso.FileExists(path);cfg=readIni(path);kidMode=firstRun?false:cfg.kidmode!="0";enabled=cfg.platforms||defaultPlatforms;if(typeof cfg.autoimport=="undefined")cfg.autoimport="1";if(typeof cfg.dailybackup=="undefined")cfg.dailybackup="1";if(typeof cfg.setupcomplete=="undefined")cfg.setupcomplete=firstRun?"0":"1";}
function saveSettings(){ensure(root+"\\Config");cfg.version="0.4.0";cfg.kidmode=kidMode?"1":"0";cfg.platforms=enabled;var path=settingsPath(),tmp=path+".new",t=fso.OpenTextFile(tmp,2,true),keys=["version","kidmode","platforms","autoimport","dailybackup","setupcomplete","lastbackup"],i;t.WriteLine("; Plugcade portable settings - safe to edit in Notepad");for(i=0;i<keys.length;i++)if(typeof cfg[keys[i]]!="undefined")t.WriteLine(keys[i]+"="+cfg[keys[i]]);t.Close();fso.CopyFile(tmp,path,true);fso.DeleteFile(tmp,true);}
function ensureTree(){var dirs=["DROP_GAMES_HERE","DROP_GAMES_HERE\\_SMART_INBOX","Library","Emulators","Saves","Backups","Config","Config\\Games","Cache","Logs"];for(var i=0;i<dirs.length;i++)ensure(root+"\\"+dirs[i]);for(i=0;i<platforms.length;i++)if(enabledPlatform(platforms[i])){ensure(root+"\\DROP_GAMES_HERE\\"+platforms[i].id);ensure(root+"\\Library\\"+platforms[i].id);ensure(root+"\\Emulators\\"+platforms[i].id);ensure(root+"\\Saves\\"+platforms[i].id);}writePlatformGuide();}
function cleanLine(s){return String(s).replace(/[\t\r\n]/g," ");}
function logEvent(kind,msg){try{ensure(root+"\\Logs");var t=fso.OpenTextFile(root+"\\Logs\\plugcade.log",8,true),d=new Date();t.WriteLine(d.getFullYear()+"-"+pad2(d.getMonth()+1)+"-"+pad2(d.getDate())+" "+pad2(d.getHours())+":"+pad2(d.getMinutes())+":"+pad2(d.getSeconds())+" ["+kind+"] "+cleanLine(msg));t.Close();}catch(e){}}
function relativePath(p){var a=String(p),r=root.toLowerCase()+"\\";return a.toLowerCase().indexOf(r)==0?"."+a.substr(root.length):a;}
function resolvePath(p){return p&&p.charAt(0)=="."?root+p.substr(1):p;}
function hashText(s){var h=5381,i;for(i=0;i<s.length;i++)h=((h<<5)+h)^s.charCodeAt(i);return (h>>>0).toString(16);}
function gameId(p,path){return p.id+"-"+hashText(relativePath(path).toLowerCase());}
function centralGameIni(g){return root+"\\Config\\Games\\"+g.id+".ini";}
function gameRun(g){var r=readKey(centralGameIni(g),"run","");if(!r)r=readKey(g.dir+"\\game.ini","run","");if(!r&&g.platform=="DOS")r=findDosTarget(fso.GetFolder(g.dir));return r;}
function saveGameRun(g,v){var t=fso.OpenTextFile(centralGameIni(g),2,true);t.WriteLine("run="+v);t.Close();g.target=v;}
function addGame(p,title,path,target,dir,mode){var id=gameId(p,path);if(seenGames[id])return;seenGames[id]=true;games[games.length]={id:id,platform:p.id,title:title,path:path,target:target||"",dir:dir,cover:coverFor(dir),mode:mode||"library",save:root+"\\Saves\\"+p.id+"\\"+id};}
function scanFolder(p,path,mode){if(!fso.FolderExists(path))return;var folder=fso.GetFolder(path),e=new Enumerator(folder.SubFolders),d,r;for(;!e.atEnd();e.moveNext()){d=e.item();if(p.kind=="dos"){var g={id:gameId(p,d.Path),platform:p.id,dir:d.Path};addGame(p,d.Name,d.Path,gameRun(g),d.Path,mode);}else{r=firstFile(d,p);if(r){var z={id:gameId(p,r),platform:p.id,dir:d.Path};addGame(p,d.Name,r,p.kind=="doscd"?gameRun(z):"",d.Path,mode);}}}e=new Enumerator(folder.Files);for(;!e.atEnd();e.moveNext()){var x=e.item();if(accepted(p,x)){var z2={id:gameId(p,x.Path),platform:p.id,dir:folder.Path};addGame(p,base(x.Name),x.Path,p.kind=="doscd"?gameRun(z2):"",folder.Path,mode);}}}
function readSources(){var a=[],path=root+"\\Config\\sources.txt",t,line,b;if(!fso.FileExists(path))return a;t=fso.OpenTextFile(path,1,false);while(!t.AtEndOfStream){line=t.ReadLine();if(line&&line.charAt(0)!="#"){b=line.split("\t");if(b.length>1)a[a.length]={platform:b[0],path:resolvePath(b[1])};}}t.Close();return a;}
function addSource(id,path){var a=readSources(),i,stored=relativePath(path);for(i=0;i<a.length;i++)if(a[i].platform==id&&a[i].path.toLowerCase()==path.toLowerCase())return false;var f=root+"\\Config\\sources.txt",t=fso.OpenTextFile(f,8,true);if(fso.GetFile(f).Size==0)t.WriteLine("# PLATFORM<TAB>FOLDER - linked folders are not copied and may not be portable");t.WriteLine(id+"\t"+stored);t.Close();return true;}
function writeManifest(){try{var path=root+"\\Config\\games.tsv",tmp=path+".new",t=fso.OpenTextFile(tmp,2,true),i,g;t.WriteLine("id\tplatform\ttitle\tcontent_path\tlaunch_target\tsave_path\tsource_mode");for(i=0;i<games.length;i++){g=games[i];t.WriteLine(cleanLine(g.id)+"\t"+cleanLine(g.platform)+"\t"+cleanLine(g.title)+"\t"+cleanLine(relativePath(g.path))+"\t"+cleanLine(g.target)+"\t"+cleanLine(relativePath(g.save))+"\t"+g.mode);}t.Close();fso.CopyFile(tmp,path,true);fso.DeleteFile(tmp,true);}catch(e){logEvent("ERROR","Could not write games catalogue: "+(e.description||e.message));}}
function render(){var h="",term=kidMode?"":document.getElementById("find").value.toLowerCase();visibleGames=[];for(var i=0;i<games.length;i++){var g=games[i],p=platform(g.platform);if(!kidMode&&current!="ALL"&&current!=g.platform)continue;if(term&&g.title.toLowerCase().indexOf(term)<0)continue;visibleGames[visibleGames.length]=i;var warn=emulatorFor(p).exe?"":'<div class="warning">Grown-up setup needed: add a compatible player</div>';if(g.mode=="linked")warn+='<div class="warning">Linked in place — not stored on this USB</div>';var cover=g.cover?'<img src="'+esc(fileUrl(g.cover))+'" alt="" />':'<span class="letter">'+esc(p.symbol)+'</span>';h+='<div id="card'+i+'" class="card" onclick="play('+i+')"><div class="cover" style="background:'+p.color+'"><span class="plat">'+esc(p.id)+'</span>'+cover+'</div><div class="info"><h2>'+esc(g.title)+'</h2><p>'+esc(p.name)+'</p><div class="cardButtons"><button class="play" onclick="cancelClick();play('+i+')">PLAY</button><button class="say" title="Say game name" onclick="cancelClick();speakGame('+i+')">SAY</button> <button class="help" title="Open help card" onclick="cancelClick();helpGame('+i+')">HELP</button></div>'+warn+'</div></div>';}if(!h)h='<div class="empty"><div class="big">P</div><h2>No games are ready yet</h2><p>Ask a grown-up to open Smart Inbox or the named system drop folders, then choose Import Now.</p></div>';document.getElementById("cards").innerHTML=h;document.getElementById("count").innerText=(visibleGames.length==games.length?games.length:visibleGames.length+" / "+games.length)+" READY";if(selected>=visibleGames.length)selected=0;paintSelected(false);}
function scan(){games=[];seenGames={};emuCache={};var i,p,sources=readSources();for(i=0;i<platforms.length;i++)if(enabledPlatform(platforms[i]))scanFolder(platforms[i],root+"\\Library\\"+platforms[i].id,"library");for(i=0;i<sources.length;i++){p=platform(sources[i].platform);if(p&&enabledPlatform(p))scanFolder(p,sources[i].path,"linked");}games.sort(function(a,b){var x=a.title.toLowerCase(),y=b.title.toLowerCase();return x<y?-1:x>y?1:0;});writeManifest();buildFilter();render();diagnose();renderTools();}
function importReset(){importStats={added:0,skipped:0,needs:[]};}
function importNeed(s){importStats.needs[importStats.needs.length]=s;logEvent("NEEDS_SORTING",s);}
function sameSize(a,b){try{return fso.GetFile(a).Size==fso.GetFile(b).Size;}catch(e){return false;}}
function copyExact(src,dst){try{if(fso.FileExists(dst)){if(sameSize(src,dst)){importStats.skipped++;return false;}importNeed("Conflict kept unchanged: "+dst);return false;}fso.CopyFile(src,dst,false);importStats.added++;return true;}catch(e){importNeed("Copy failed: "+src+" - "+(e.description||e.message));return false;}}
function importGameFolder(path,p){var d=fso.GetFolder(path),to=root+"\\Library\\"+p.id+"\\"+safeName(d.Name);if(fso.FolderExists(to)){importStats.skipped++;return 0;}try{fso.CopyFolder(d.Path,to,false);importStats.added++;return 1;}catch(e){importNeed("Folder copy failed: "+d.Path);return 0;}}
function copyFolders(src,dst){if(!fso.FolderExists(src))return 0;var count=0,e=new Enumerator(fso.GetFolder(src).SubFolders);for(;!e.atEnd();e.moveNext()){var d=e.item(),to=dst+"\\"+safeName(d.Name);if(fso.FolderExists(to)){importStats.skipped++;continue;}try{fso.CopyFolder(d.Path,to,false);count++;importStats.added++;}catch(x){importNeed("Folder copy failed: "+d.Path);}}return count;}
function cueFiles(path){var a=[],t,line,re=/^\s*FILE\s+(?:"([^"]+)"|(\S+))/i,m;if(!fso.FileExists(path))return a;t=fso.OpenTextFile(path,1,false);while(!t.AtEndOfStream){line=t.ReadLine();m=re.exec(line);if(m)a[a.length]=m[1]||m[2];}t.Close();return a;}
function importDisc(x,p,dst){var title=base(x.Name),dir=dst+"\\"+safeName(title),z=ext(x.Name),srcDir=fso.GetParentFolderName(x.Path),list=[],i,name;ensure(dir);copyExact(x.Path,dir+"\\"+x.Name);if(z=="cue")list=cueFiles(x.Path);else if(z=="ccd")list=[title+".img",title+".sub"];else if(z=="mds")list=[title+".mdf"];for(i=0;i<list.length;i++){name=fso.GetFileName(list[i]);if(fso.FileExists(srcDir+"\\"+name))copyExact(srcDir+"\\"+name,dir+"\\"+name);else importNeed("Missing disc track for "+x.Name+": "+name);}return 1;}
function copyLoose(src,dst,p){if(!fso.FolderExists(src))return 0;var count=0,e=new Enumerator(fso.GetFolder(src).Files);for(;!e.atEnd();e.moveNext()){var x=e.item();if(!accepted(p,x))continue;if(p.kind=="disc"||p.kind=="doscd"){if(ext(x.Name)!="cue"&&ext(x.Name)!="iso"&&ext(x.Name)!="chd"&&ext(x.Name)!="ccd"&&ext(x.Name)!="mds")continue;count+=importDisc(x,p,dst);}else{var d=dst+"\\"+safeName(base(x.Name));ensure(d);if(copyExact(x.Path,d+"\\"+x.Name))count++;}}return count;}
function importLooseFile(x,p){var dst=root+"\\Library\\"+p.id;if(p.kind=="disc"||p.kind=="doscd")return importDisc(x,p,dst);var d=dst+"\\"+safeName(base(x.Name));ensure(d);return copyExact(x.Path,d+"\\"+x.Name)?1:0;}
function importSource(src,p){ensure(root+"\\Library\\"+p.id);return copyFolders(src,root+"\\Library\\"+p.id)+copyLoose(src,root+"\\Library\\"+p.id,p);}
function candidates(z){var a=[],i,p;if(z=="zip")return a;if(z=="cue"||z=="iso"||z=="chd"||z=="ccd"||z=="mds")return[platform("CD"),platform("SEGACD"),platform("PS1")];for(i=0;i<platforms.length;i++){p=platforms[i];if(p.kind!="dos"&&contains(p.exts,z))a[a.length]=p;}return a;}
function enableOne(p){if(!enabledPlatform(p)){enabled+=(enabled?",":"")+p.id;ensureTree();}}
function guessFolder(d){var named=matchFolder(d.Name);if(named)return{p:named,container:true};if(findDosTarget(d))return{p:platform("DOS"),container:false};var found={},count=0,only=null,e=new Enumerator(d.Files);for(;!e.atEnd();e.moveNext()){var a=candidates(ext(e.item().Name));if(a.length==1&&!found[a[0].id]){found[a[0].id]=true;count++;only=a[0];}}return count==1?{p:only,container:false}:null;}
function smartImport(){var path=root+"\\DROP_GAMES_HERE\\_SMART_INBOX",folder,e,a,g;if(!fso.FolderExists(path))return;folder=fso.GetFolder(path);e=new Enumerator(folder.Files);for(;!e.atEnd();e.moveNext()){var x=e.item();a=candidates(ext(x.Name));if(a.length==1){enableOne(a[0]);importLooseFile(x,a[0]);}else if(ext(x.Name)!="txt")importNeed("Choose a system folder for "+x.Name);}e=new Enumerator(folder.SubFolders);for(;!e.atEnd();e.moveNext()){var d=e.item();g=guessFolder(d);if(!g){importNeed("Could not safely identify folder: "+d.Name);continue;}enableOne(g.p);if(g.container)importSource(d.Path,g.p);else importGameFolder(d.Path,g.p);}}
function showImportReport(){if(!importStats)return;var p=document.getElementById("importReport"),h='<h2>Last import</h2><span class="miniStatus">'+importStats.added+' ADDED</span><span class="miniStatus">'+importStats.skipped+' ALREADY THERE</span>';if(importStats.needs.length){h+='<p><b>Needs a grown-up decision:</b></p><div class="reportList">';for(var i=0;i<importStats.needs.length;i++)h+=esc(importStats.needs[i])+"<br />";h+='</div>';}else h+='<p class="ok">Everything recognized was handled safely. Originals were left untouched.</p>';p.innerHTML=h;p.className="panel adultOnly";}
function doImport(silent){importReset();var i,p;for(i=0;i<platforms.length;i++)if(enabledPlatform(platforms[i])){p=platforms[i];importSource(root+"\\DROP_GAMES_HERE\\"+p.id,p);}smartImport();saveSettings();showImportReport();logEvent("IMPORT",importStats.added+" added, "+importStats.skipped+" skipped, "+importStats.needs.length+" need sorting");scan();if(!silent)alert(importStats.added+" item(s) added. "+importStats.skipped+" already existed. "+importStats.needs.length+" need a grown-up decision.\n\nOriginal files were not deleted or moved.");}
function collectionMatches(path){var a=[],folder=fso.GetFolder(path),p=matchFolder(folder.Name),e;if(p)a[a.length]={p:p,path:path};else{e=new Enumerator(folder.SubFolders);for(;!e.atEnd();e.moveNext()){var d=e.item();p=matchFolder(d.Name);if(p)a[a.length]={p:p,path:d.Path};}}return a;}
function chooseCollection(mode){var app=new ActiveXObject("Shell.Application"),picked=app.BrowseForFolder(0,mode=="link"?"Choose an organized collection to use in place (no copy).":"Choose an organized collection to copy safely into Plugcade.",0,0);if(!picked)return;var path=picked.Self.Path,a=collectionMatches(path),i,total=0;if(!a.length){alert("No recognizable system folders were found.\n\nUse names such as NES, SNES, GBA, GENESIS, PS1, ARCADE or DOS.");return;}importReset();for(i=0;i<a.length;i++){enableOne(a[i].p);if(mode=="link"){if(addSource(a[i].p.id,a[i].path))total++;}else total+=importSource(a[i].path,a[i].p);}saveSettings();if(mode=="link")alert(total+" system folder(s) linked without copying.\n\nLinked content stays where it is and may not travel with the USB.");else{showImportReport();alert(importStats.added+" item(s) copied. Originals were not deleted or moved.");}scan();}
function addCollection(){chooseCollection("copy");}
function linkCollection(){chooseCollection("link");}
</script>
<script language="JScript">
function exeScore(name,p,depth){var n=name.toLowerCase(),bad=["setup","install","unins","uninstall","update","crash","report","config","redist"],i,score=20-depth*3;for(i=0;i<bad.length;i++)if(n.indexOf(bad[i])>=0)return-1000;if(p.id=="DOS"&&n.indexOf("dosbox")>=0)score+=100;if(n.indexOf(p.id.toLowerCase())>=0)score+=15;var al=p.aliases.toLowerCase().split(",");for(i=0;i<al.length;i++)if(al[i].length>2&&n.indexOf(al[i])>=0)score+=8;return score;}
function findExe(folder,p,depth,state){var e,x,s;if(!fso.FolderExists(folder))return;e=new Enumerator(fso.GetFolder(folder).Files);for(;!e.atEnd();e.moveNext()){x=e.item();if(ext(x.Name)=="exe"){state.count++;s=exeScore(x.Name,p,depth);if(s>state.score){state.score=s;state.path=x.Path;}}}if(depth>=2)return;e=new Enumerator(fso.GetFolder(folder).SubFolders);for(;!e.atEnd();e.moveNext())findExe(e.item().Path,p,depth+1,state);}
function emulatorFor(p){if(emuCache[p.id])return emuCache[p.id];var dir=root+"\\Emulators\\"+p.id,ini=dir+"\\emulator.ini",run=readKey(ini,"run",""),args=readKey(ini,"args",'"%ROM%"'),exe="",state={path:"",score:-9999,count:0};if(run&&fso.FileExists(dir+"\\"+run))exe=dir+"\\"+run;if(!exe){findExe(dir,p,0,state);exe=state.path;}return emuCache[p.id]={exe:exe,args:args,count:state.count,automatic:!run&&!!exe};}
function dosbox(){return emulatorFor(platform("DOS")).exe;}
function gameSaveDir(g){ensure(root+"\\Saves\\"+g.platform);ensure(g.save);return g.save;}
function copyMissing(src,dst){if(!fso.FolderExists(src))return;ensure(dst);var e=new Enumerator(fso.GetFolder(src).Files),x,to;for(;!e.atEnd();e.moveNext()){x=e.item();to=dst+"\\"+x.Name;if(!fso.FileExists(to))try{fso.CopyFile(x.Path,to,false);}catch(z){logEvent("ERROR","Could not prepare DOS work copy: "+x.Path);}}e=new Enumerator(fso.GetFolder(src).SubFolders);for(;!e.atEnd();e.moveNext()){x=e.item();copyMissing(x.Path,dst+"\\"+x.Name);}}
function prepareDos(g){var work=gameSaveDir(g)+"\\Game";if(!fso.FolderExists(work)){fso.CopyFolder(g.path,work,false);logEvent("SAVE","Created DOS working copy for "+g.title);}else copyMissing(g.path,work);return work;}
function pickDosTarget(g){var v=window.prompt("Enter the DOS program to start (example: GAME.EXE). Plugcade will remember it.",g.target||"");if(!v)return"";if(!fso.FileExists(g.dir+"\\"+v)){alert("That file was not found in:\n"+g.dir);return"";}saveGameRun(g,v);return v;}
function pickDosCdTarget(g){var v=window.prompt("Enter the program INSIDE the CD image to start after it mounts (example: INSTALL.EXE or GAME.BAT). Plugcade will remember it.",g.target||"INSTALL.EXE");if(!v)return"";saveGameRun(g,v);return v;}
function recordLaunch(g){try{var t=fso.OpenTextFile(root+"\\Config\\recent.tsv",8,true);t.WriteLine(timeKey()+"\t"+g.id+"\t"+cleanLine(g.title));t.Close();}catch(e){}logEvent("LAUNCH",g.platform+" - "+g.title);}
function play(i){var g=games[i],p=platform(g.platform),emu,conf,t,dir,info,args,target,oldDir;try{gameSaveDir(g);if(p.kind=="dos"||p.kind=="doscd"){emu=dosbox();if(!emu){speak("Ask a grown-up to set up the DOS player.");alert("DOS emulator missing.\n\nPut a portable DOSBox or DOSBox-X folder anywhere inside:\n"+root+"\\Emulators\\DOS\n\nPlugcade searches two folders deep automatically.");return;}target=g.target||gameRun(g);if(p.kind=="dos"&&!target)target=pickDosTarget(g);if(p.kind=="doscd"&&!target)target=pickDosCdTarget(g);if(!target)return;conf=root+"\\Cache\\launch-"+g.id+".conf";t=fso.OpenTextFile(conf,2,true);t.WriteLine("[sdl]");t.WriteLine("fullscreen=true");t.WriteLine("[autoexec]");if(p.kind=="dos"){dir=prepareDos(g);t.WriteLine('mount c "'+dir+'"');t.WriteLine("c:");t.WriteLine('call "'+target+'"');}else{dir=gameSaveDir(g)+"\\CDrive";ensure(dir);t.WriteLine('mount c "'+dir+'"');t.WriteLine('imgmount d "'+g.path+'" -t iso');t.WriteLine("d:");t.WriteLine('call "'+target+'"');}t.WriteLine("exit");t.Close();recordLaunch(g);shell.Run(q(emu)+" -conf "+q(conf)+" -exit",1,false);return;}info=emulatorFor(p);if(!info.exe){speak("Ask a grown-up to set up the "+p.name+" player.");alert("No "+p.name+" emulator was found.\n\nPut its portable folder anywhere inside:\n"+root+"\\Emulators\\"+p.id+"\n\nPlugcade searches two folders deep. Optional emulator.ini can set run= and args=.");return;}args=info.args;args=token(args,"%ROM%",g.path);args=token(args,"%ROOT%",root);args=token(args,"%SAVES%",root+"\\Saves\\"+p.id);args=token(args,"%GAME_SAVES%",gameSaveDir(g));args=token(args,"%GAME_DIR%",g.dir);args=token(args,"%ID%",g.id);args=token(args,"%TITLE%",g.title);try{oldDir=shell.CurrentDirectory;shell.CurrentDirectory=fso.GetParentFolderName(info.exe);}catch(x){}recordLaunch(g);shell.Run(q(info.exe)+" "+args,1,false);try{if(oldDir)shell.CurrentDirectory=oldDir;}catch(y){}}catch(e){logEvent("ERROR","Launch failed for "+g.title+": "+(e.description||e.message));alert("Plugcade could not launch "+g.title+".\n\n"+(e.description||e.message)+"\n\nOpen SYSTEM CHECK or Logs for details.");}}
function hasFiles(path){if(!fso.FolderExists(path))return false;var f=fso.GetFolder(path),e=new Enumerator(f.Files);if(!e.atEnd())return true;e=new Enumerator(f.SubFolders);for(;!e.atEnd();e.moveNext())if(hasFiles(e.item().Path))return true;return false;}
function folderBytes(path){if(!fso.FolderExists(path))return 0;var total=0,e=new Enumerator(fso.GetFolder(path).Files);for(;!e.atEnd();e.moveNext())total+=e.item().Size;e=new Enumerator(fso.GetFolder(path).SubFolders);for(;!e.atEnd();e.moveNext())total+=folderBytes(e.item().Path);return total;}
function trimBackups(){var p=root+"\\Backups",a=[],e=new Enumerator(fso.GetFolder(p).SubFolders),d;for(;!e.atEnd();e.moveNext()){d=e.item();if(d.Name.indexOf("Saves_")==0)a[a.length]={name:d.Name,path:d.Path};}a.sort(function(x,y){return x.name<y.name?-1:x.name>y.name?1:0;});while(a.length>3){d=a.shift();try{fso.DeleteFolder(d.path,true);logEvent("BACKUP","Removed oldest automatic backup "+d.name);}catch(x){break;}}}
function backupSaves(manual){var src=root+"\\Saves",dst=root+"\\Backups\\Saves_"+timeKey(),bytes;if(!hasFiles(src)){if(manual)alert("There are no save files to back up yet.");return false;}bytes=folderBytes(src);if(bytes>268435456&&!manual){logEvent("BACKUP","Daily backup skipped because Saves is larger than 256 MB");return false;}if(bytes>268435456&&manual&&!confirm("Your Saves folder is larger than 256 MB. Back it up anyway?"))return false;try{fso.CopyFolder(src,dst,false);cfg.lastbackup=dayKey();saveSettings();trimBackups();logEvent("BACKUP","Saved portable backup to "+dst);if(manual)alert("Save backup created:\n"+dst+"\n\nPlugcade keeps the newest three dated backups.");return true;}catch(e){logEvent("ERROR","Save backup failed: "+(e.description||e.message));if(manual)alert("Save backup failed. Check free space and write access.");return false;}}
function dailyBackup(){if(cfg.dailybackup!="0"&&cfg.lastbackup!=dayKey())backupSaves(false);}
function driveInfo(){var o={os:"Windows",arch:"Unknown",drive:"Folder",fs:"Unknown",free:"Unknown",write:"NO"},test=root+"\\Config\\.write-test";try{o.os=shell.RegRead("HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\ProductName");}catch(e){try{o.os=shell.RegRead("HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\ProductName");}catch(x){}}try{o.arch=shell.ExpandEnvironmentStrings("%PROCESSOR_ARCHITECTURE%");}catch(y){}try{var d=fso.GetDrive(fso.GetDriveName(root));o.drive=d.DriveType==1?"Removable USB":"Local / fixed folder";o.fs=d.FileSystem;o.free=Math.round(d.AvailableSpace/1048576)+" MB free";}catch(z){}try{var t=fso.OpenTextFile(test,2,true);t.Write("ok");t.Close();fso.DeleteFile(test,true);o.write="YES";}catch(w){}return o;}
function diagnose(){var o=driveInfo(),sources=readSources(),d='<h2>System check</h2><div class="row">Computer: <b>'+esc(o.os)+'</b> · '+esc(o.arch)+'</div><div class="row">Plugcade: <b>'+esc(o.drive)+'</b> · '+esc(o.fs)+' · '+esc(o.free)+' · Write access: <span class="'+(o.write=="YES"?"ok":"bad")+'">'+o.write+'</span></div><div class="row">Catalogue: <b>'+games.length+' games</b> · '+sources.length+' linked source(s) · Mode: <b>'+(kidMode?"KID":"GROWN-UP")+'</b></div>',readyCount=0;for(var i=0;i<platforms.length;i++)if(enabledPlatform(platforms[i])){var p=platforms[i],info=emulatorFor(p),ready=!!info.exe;if(ready)readyCount++;d+='<div class="row">'+esc(p.name)+': <span class="'+(ready?"ok":"bad")+'">'+(ready?"READY - "+esc(fso.GetFileName(info.exe))+(info.automatic?" (auto-detected)":""):"EMULATOR NEEDED")+'</span></div>';}d='<span class="miniStatus">'+readyCount+' EMULATORS READY</span>'+d;document.getElementById("diagnostics").innerHTML=d;}
function paintSelected(scroll){for(var i=0;i<visibleGames.length;i++){var c=document.getElementById("card"+visibleGames[i]);if(c)c.className="card"+(i==selected?" selected":"");}if(scroll&&visibleGames.length){var s=document.getElementById("card"+visibleGames[selected]);if(s)try{s.scrollIntoView(false);}catch(e){}}}
function keyNav(){if(!kidMode||!visibleGames.length)return;var e=window.event,k=e.keyCode,ov=document.getElementById("overlay");if(ov.style.display=="block"){if(k==27||k==72||k==13)closeHelp();e.returnValue=false;return;}if(k==37||k==38||k==33){selected-=k==33?4:1;if(selected<0)selected=visibleGames.length-1;paintSelected(true);e.returnValue=false;}else if(k==39||k==40||k==34){selected+=k==34?4:1;if(selected>=visibleGames.length)selected=0;paintSelected(true);e.returnValue=false;}else if(k==13){play(visibleGames[selected]);e.returnValue=false;}else if(k==32){speakGame(visibleGames[selected]);e.returnValue=false;}else if(k==72){helpGame(visibleGames[selected]);e.returnValue=false;}}
function openFolder(p){ensure(p);shell.Run("explorer.exe "+q(p),1,false);}
function openDrop(){openFolder(root+"\\DROP_GAMES_HERE");}
function openSmart(){openFolder(root+"\\DROP_GAMES_HERE\\_SMART_INBOX");}
function openEmulators(){openFolder(root+"\\Emulators");}
function openSaves(){openFolder(root+"\\Saves");}
function openLogs(){openFolder(root+"\\Logs");}
function toggleTools(){togglePanel("toolsPanel");renderTools();}
function renderTools(){var p=document.getElementById("toolsPanel");if(!p)return;var ready=0,i;for(i=0;i<platforms.length;i++)if(enabledPlatform(platforms[i])&&emulatorFor(platforms[i]).exe)ready++;p.innerHTML='<h2>'+(cfg.setupcomplete=="1"?'Setup & automation':'Welcome — let’s build this Plugcade')+'</h2><p class="setupLead">One grown-up setup. After that, Kid Mode is plug, pick and play.</p><span class="miniStatus">'+games.length+' GAMES</span><span class="miniStatus">'+ready+' PLAYERS READY</span><span class="miniStatus">'+readSources().length+' LINKED FOLDERS</span><div class="setupSteps"><div class="setupStep"><b>1 · PLAYERS</b><span>Put each portable emulator folder inside Emulators\\SYSTEM. Nested EXEs are found automatically.</span><button class="action" onclick="openEmulators()">OPEN EMULATORS</button></div><div class="setupStep"><b>2 · GAMES</b><span>Use named system folders—or try Smart Inbox for files Plugcade can identify safely.</span><button class="action smart" onclick="openSmart()">OPEN SMART INBOX</button></div><div class="setupStep"><b>3 · READY</b><span>Import copies safely. Link uses a collection where it already lives and saves space.</span><button class="action import" onclick="doImport(false)">IMPORT NOW</button></div></div><div class="panelButtons"><button class="action" onclick="addCollection()">COPY A COLLECTION</button><button class="action" onclick="linkCollection()">LINK WITHOUT COPYING</button><button class="action systems" onclick="showSystems()">CHOOSE SYSTEMS</button><button class="action" onclick="togglePanel(\'diagnostics\')">SYSTEM CHECK</button><button class="action" onclick="backupSaves(true)">BACK UP SAVES NOW</button><button class="action" onclick="openSaves()">OPEN SAVES</button><button class="action" onclick="openLogs()">OPEN LOGS</button></div><div class="autoBox"><label><input id="autoImport" type="checkbox" '+(cfg.autoimport!="0"?'checked="checked"':'')+' /> Check drop folders when Plugcade starts</label><label><input id="dailyBackup" type="checkbox" '+(cfg.dailybackup!="0"?'checked="checked"':'')+' /> Make one save backup per day</label><button class="action" onclick="saveOptions()">SAVE AUTOMATION</button>'+(cfg.setupcomplete!="1"?'<button class="action import" onclick="finishSetup()">FINISH SETUP → KID MODE</button>':'')+'</div>';}
function saveOptions(){cfg.autoimport=document.getElementById("autoImport").checked?"1":"0";cfg.dailybackup=document.getElementById("dailyBackup").checked?"1":"0";saveSettings();alert("Automation settings saved.");}
function finishSetup(){cfg.setupcomplete="1";kidMode=true;saveSettings();document.getElementById("toolsPanel").className="panel hidden adultOnly";applyMode();render();diagnose();if(games.length)speak("Plugcade is ready. Use the arrow keys to choose a game. Press enter to play.");}
function init(){root=pathFromUrl();ensure(root+"\\Config");loadSettings();ensureTree();applyMode();document.onkeydown=keyNav;try{window.resizeTo(1120,780);}catch(e){}if(firstRun)logEvent("SETUP","First run started in "+root);if(cfg.autoimport!="0")doImport(true);else scan();dailyBackup();renderTools();if(cfg.setupcomplete!="1"){document.getElementById("toolsPanel").className="panel adultOnly";}if(kidMode&&games.length)speak("Plugcade is ready. Use the arrow keys to choose a game. Press enter to play.");}
</script>
</head>
<body onload="init()">
<div class="top"><div class="logo">PLUGCADE</div><div class="tag">YOUR ARCADE. ANYWHERE.</div><div class="status" id="count">LOADING...</div><button id="modeButton" class="mode" onclick="toggleMode()">GROWN-UP MODE</button><div class="clear"></div></div>
<div class="hero"><h1>Your games. <b>Your rules.</b></h1><p>Portable. Offline. Friendly for kids. Configurable by grown-ups.</p></div>
<div class="kidGuide"><span><i>&larr;&rarr;</i> CHOOSE</span><span><i>&crarr;</i> PLAY</span><span><i>H</i> HELP</span><span><i>_</i> SAY NAME</span></div>
<div class="toolbar adultOnly"><select id="platformFilter" onchange="changeFilter()"><option value="ALL">ALL SYSTEMS</option></select><button class="action import" onclick="doImport(false)">IMPORT NOW</button><button class="action smart" onclick="openSmart()">SMART INBOX</button><button class="action" onclick="openDrop()">SYSTEM DROP FOLDERS</button><button class="action systems" onclick="toggleTools()">SETUP &amp; TOOLS</button></div>
<div class="search adultOnly"><input id="find" type="text" onkeyup="render()" placeholder="Find a game..." /></div>
<div id="toolsPanel" class="panel hidden adultOnly"></div><div id="importReport" class="panel hidden adultOnly"></div><div id="systemsPanel" class="panel hidden adultOnly"></div><div id="diagnostics" class="panel hidden adultOnly"></div><div id="cards" class="content"></div>
<div id="overlay" class="overlay"><div class="helpbox"><h2 id="helpTitle">Game help</h2><div id="helpText" class="helpText"></div><p><button class="close" onclick="closeHelp()">BACK TO GAMES</button></p></div></div>
<div class="foot">PLUGCADE 0.4 ALPHA · SMART IMPORT · PORTABLE SAVE BACKUPS · NO INTERNET REQUIRED · USER-SUPPLIED GAMES ONLY</div>
</body></html>
