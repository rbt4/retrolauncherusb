<!DOCTYPE html>
<html>
<head>
<title>Plugcade</title>
<HTA:APPLICATION ID="plugcade" APPLICATIONNAME="Plugcade" VERSION="0.2.0" BORDER="thick" CAPTION="yes" SHOWINTASKBAR="yes" SINGLEINSTANCE="yes" SCROLL="yes" WINDOWSTATE="normal" />
<meta http-equiv="X-UA-Compatible" content="IE=8" />
<style type="text/css">
html,body{margin:0;padding:0;background:#fff4df;color:#211a37;font-family:Verdana,Arial,sans-serif;font-size:13px}button,input,select{font-family:Verdana,Arial,sans-serif}.top{background:#fffaf0;border-bottom:4px solid #211a37;padding:14px 20px;height:46px}.logo{float:left;font-family:Courier New,monospace;font-weight:bold;font-size:25px;color:#ff522e;letter-spacing:-2px}.tag{float:left;margin:7px 0 0 14px;font-size:10px;font-weight:bold;letter-spacing:1px}.status{float:right;margin-top:5px;background:#dff5e6;border:2px solid #211a37;padding:7px 11px;font-weight:bold}.hero{background:#ff522e;color:#211a37;border-bottom:4px solid #211a37;padding:22px 24px}.hero h1{color:white;font-size:31px;margin:0 0 4px 0;text-shadow:3px 3px 0 #211a37}.hero b{color:#ffd13b}.hero p{margin:0;font-weight:bold}.toolbar{padding:16px 20px 10px 20px;overflow:hidden}.tabs{float:left}.tab,.action{border:2px solid #211a37;background:#fffaf0;padding:8px 13px;margin:0 7px 6px 0;font-weight:bold;cursor:pointer;box-shadow:3px 3px 0 #211a37}.tab.on{background:#211a37;color:white;box-shadow:none}.action{float:right;background:#ffd13b}.action.import{background:#38b86d}.search{clear:both;padding:0 20px 12px 20px}.search input{width:96%;border:3px solid #211a37;padding:9px;background:white;font-size:14px}.content{padding:0 18px 30px 18px}.card{display:inline-block;vertical-align:top;width:225px;margin:8px;border:3px solid #211a37;background:#fffaf0;box-shadow:5px 5px 0 #211a37;cursor:pointer}.cover{height:92px;border-bottom:3px solid #211a37;padding:15px;overflow:hidden}.cover .letter{font-family:Courier New,monospace;font-weight:bold;font-size:52px;color:#ffd13b;text-shadow:3px 3px 0 #211a37}.cover .plat{float:right;background:#211a37;color:white;padding:4px;font-size:9px}.info{padding:12px}.info h2{font-size:18px;margin:0 0 3px 0}.info p{color:#746b80;margin:0 0 12px 0;height:30px}.play{display:block;width:100%;border:2px solid #211a37;background:#ffd13b;padding:8px;font-weight:bold;cursor:pointer}.warning{background:#fff0bd;border:2px solid #211a37;padding:9px;margin-top:8px;font-size:11px}.empty{margin:25px;padding:25px;border:3px dashed #211a37;text-align:center}.panel{margin:12px 20px 25px 20px;padding:17px;border:3px solid #211a37;background:#fffaf0;box-shadow:5px 5px 0 #211a37}.panel h2{margin-top:0}.row{padding:9px 0;border-bottom:1px solid #dfd1b7}.ok{color:#147a42;font-weight:bold}.bad{color:#c43d2f;font-weight:bold}.foot{background:#211a37;color:white;padding:13px 20px;font-size:10px}.clear{clear:both}.hidden{display:none}
</style>
<script language="JScript">
var fso=new ActiveXObject("Scripting.FileSystemObject");
var shell=new ActiveXObject("WScript.Shell");
var root="",current="ALL",games=[],colors=["#1677d2","#1d9c62","#c43d2f","#f1b91d","#6659a7","#ed5a2a"];
function esc(s){return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/\"/g,"&quot;");}
function q(s){return '"'+String(s).replace(/"/g,'""')+'"';}
function pathFromUrl(){var p=unescape(location.pathname);if(p.charAt(0)=="/"&&p.charAt(2)==":")p=p.substr(1);p=p.replace(/\//g,"\\");return fso.GetParentFolderName(p);}
function ensure(p){if(!fso.FolderExists(p))fso.CreateFolder(p);}
function ensureTree(){ensure(root+"\\DROP_GAMES_HERE");ensure(root+"\\DROP_GAMES_HERE\\DOS");ensure(root+"\\DROP_GAMES_HERE\\GBA");ensure(root+"\\DROP_GAMES_HERE\\CD-ROM");ensure(root+"\\Library");ensure(root+"\\Library\\DOS");ensure(root+"\\Library\\GBA");ensure(root+"\\Library\\CD-ROM");ensure(root+"\\Emulators");ensure(root+"\\Emulators\\DOS");ensure(root+"\\Emulators\\GBA");ensure(root+"\\Saves");ensure(root+"\\Backups");ensure(root+"\\Config");ensure(root+"\\Cache");ensure(root+"\\Logs");}
function ext(n){var i=n.lastIndexOf(".");return i<0?"":n.substr(i+1).toLowerCase();}
function base(n){var i=n.lastIndexOf(".");return i<0?n:n.substr(0,i);}
function safeName(n){return n.replace(/[\\\/:*?\"<>|]/g,"_");}
function firstFile(folder,exts){var e=new Enumerator(folder.Files);for(;!e.atEnd();e.moveNext()){var x=e.item(),z=ext(x.Name);for(var i=0;i<exts.length;i++)if(z==exts[i])return x.Path;}return "";}
function findDosTarget(folder){var bad=" setup install config uninstall unins patch update register readme help ",best="",count=0;var e=new Enumerator(folder.Files);for(;!e.atEnd();e.moveNext()){var x=e.item(),z=ext(x.Name);if(z=="exe"||z=="com"||z=="bat"){var n=" "+base(x.Name).toLowerCase()+" ";if(bad.indexOf(n)>=0)continue;if(!best)best=x.Name;count++;}}return count==1?best:"";}
function readRun(folder){var ini=folder.Path+"\\game.ini";if(fso.FileExists(ini)){var t=fso.OpenTextFile(ini,1,false),line;while(!t.AtEndOfStream){line=t.ReadLine();if(line.toLowerCase().indexOf("run=")==0){t.Close();return line.substr(4);}}t.Close();}return findDosTarget(folder);}
function addGame(platform,title,path,target){games[games.length]={platform:platform,title:title,path:path,target:target};}
function scanFolders(platform,p){if(!fso.FolderExists(p))return;var e=new Enumerator(fso.GetFolder(p).SubFolders);for(;!e.atEnd();e.moveNext()){var d=e.item();if(platform=="DOS")addGame(platform,d.Name,d.Path,readRun(d));else if(platform=="GBA"){var r=firstFile(d,["gba","zip"]);if(r)addGame(platform,d.Name,r,"");}else{var c=firstFile(d,["cue","iso","ccd","mds"]);if(c)addGame(platform,d.Name,c,readRun(d));}}}
function scanLooseGba(){var p=root+"\\Library\\GBA";if(!fso.FolderExists(p))return;var e=new Enumerator(fso.GetFolder(p).Files);for(;!e.atEnd();e.moveNext()){var x=e.item();if(ext(x.Name)=="gba"||ext(x.Name)=="zip")addGame("GBA",base(x.Name),x.Path,"");}}
function scan(){games=[];scanFolders("DOS",root+"\\Library\\DOS");scanFolders("GBA",root+"\\Library\\GBA");scanLooseGba();scanFolders("CD",root+"\\Library\\CD-ROM");render();diagnose();}
function render(){var h="",term=document.getElementById("find").value.toLowerCase();for(var i=0;i<games.length;i++){var g=games[i];if(current!="ALL"&&current!=g.platform)continue;if(term&&g.title.toLowerCase().indexOf(term)<0)continue;var warn=(g.platform!="GBA"&&!g.target)?'<div class="warning">Needs launch-file setup</div>':"";h+='<div class="card" onclick="play('+i+')"><div class="cover" style="background:'+colors[i%colors.length]+'"><span class="plat">'+g.platform+'</span><span class="letter">'+esc(g.title.charAt(0).toUpperCase())+'</span></div><div class="info"><h2>'+esc(g.title)+'</h2><p>'+esc(g.platform=="DOS"?"DOS game":g.platform=="GBA"?"Game Boy Advance":"DOS CD-ROM image")+'</p><button class="play">PLAY</button>'+warn+'</div></div>';}if(!h)h='<div class="empty"><h2>No games here yet</h2><p>Put your files into DROP_GAMES_HERE, then click IMPORT GAMES.</p></div>';document.getElementById("cards").innerHTML=h;document.getElementById("count").innerText=games.length+" GAMES READY";}
function tab(v){current=v;var ids=["ALL","DOS","GBA","CD"];for(var i=0;i<ids.length;i++)document.getElementById("t"+ids[i]).className="tab"+(ids[i]==v?" on":"");render();}
function pickDosTarget(g){var d=fso.GetFolder(g.platform=="CD"?fso.GetParentFolderName(g.path):g.path),v=window.prompt("Enter the exact game executable inside this folder (example: GAME.EXE)","");if(!v)return "";if(!fso.FileExists(d.Path+"\\"+v)){alert("That file was not found in:\n"+d.Path);return "";}var t=fso.OpenTextFile(d.Path+"\\game.ini",2,true);t.WriteLine("run="+v);t.Close();g.target=v;return v;}
function dosbox(){var a=[root+"\\Emulators\\DOS\\dosbox-x.exe",root+"\\Emulators\\DOS\\dosbox.exe"];for(var i=0;i<a.length;i++)if(fso.FileExists(a[i]))return a[i];return "";}
function gbaemu(){var a=[root+"\\Emulators\\GBA\\mGBA.exe",root+"\\Emulators\\GBA\\VisualBoyAdvance-M.exe",root+"\\Emulators\\GBA\\VisualBoyAdvance.exe"];for(var i=0;i<a.length;i++)if(fso.FileExists(a[i]))return a[i];return "";}
function play(i){var g=games[i],emu,conf,t,dir;if(g.platform=="GBA"){emu=gbaemu();if(!emu){alert("No GBA emulator found.\n\nPlace mGBA.exe or VisualBoyAdvance.exe in:\n"+root+"\\Emulators\\GBA");return;}shell.Run(q(emu)+" "+q(g.path),1,false);return;}emu=dosbox();if(!emu){alert("No DOS emulator found.\n\nPlace dosbox-x.exe or dosbox.exe in:\n"+root+"\\Emulators\\DOS");return;}if(!g.target&&!pickDosTarget(g))return;conf=root+"\\Cache\\launch.conf";t=fso.OpenTextFile(conf,2,true);t.WriteLine("[sdl]");t.WriteLine("fullscreen=true");t.WriteLine("[autoexec]");if(g.platform=="DOS"){dir=g.path;t.WriteLine('mount c "'+dir+'"');t.WriteLine("c:");t.WriteLine('call "'+g.target+'"');}else{dir=fso.GetParentFolderName(g.path);t.WriteLine('mount c "'+dir+'"');t.WriteLine('imgmount d "'+g.path+'" -t iso');t.WriteLine("d:");t.WriteLine('call "'+g.target+'"');}t.WriteLine("exit");t.Close();shell.Run(q(emu)+" -conf "+q(conf)+" -exit",1,false);}
function copyFolderContents(src,dst){if(!fso.FolderExists(src))return 0;var sf=fso.GetFolder(src),count=0,e=new Enumerator(sf.SubFolders);for(;!e.atEnd();e.moveNext()){var d=e.item(),to=dst+"\\"+safeName(d.Name);if(fso.FolderExists(to)){if(!confirm("A game named "+d.Name+" already exists. Replace its imported copy?"))continue;fso.DeleteFolder(to,true);}fso.CopyFolder(d.Path,to,true);count++;}return count;}
function importGba(){var src=root+"\\DROP_GAMES_HERE\\GBA",dst=root+"\\Library\\GBA",count=0,e=new Enumerator(fso.GetFolder(src).Files);for(;!e.atEnd();e.moveNext()){var x=e.item(),z=ext(x.Name);if(z!="gba"&&z!="zip")continue;var d=dst+"\\"+safeName(base(x.Name));ensure(d);var to=d+"\\"+x.Name;if(!fso.FileExists(to)||confirm(x.Name+" is already imported. Replace the copy?")){fso.CopyFile(x.Path,to,true);count++;}}return count;}
function importCdLoose(){var src=root+"\\DROP_GAMES_HERE\\CD-ROM",dst=root+"\\Library\\CD-ROM",count=0,e=new Enumerator(fso.GetFolder(src).Files);for(;!e.atEnd();e.moveNext()){var x=e.item(),z=ext(x.Name);if(z!="cue"&&z!="iso"&&z!="ccd"&&z!="mds")continue;var d=dst+"\\"+safeName(base(x.Name));ensure(d);fso.CopyFile(x.Path,d+"\\"+x.Name,true);count++;}return count;}
function doImport(){var total=0;total+=copyFolderContents(root+"\\DROP_GAMES_HERE\\DOS",root+"\\Library\\DOS");total+=copyFolderContents(root+"\\DROP_GAMES_HERE\\GBA",root+"\\Library\\GBA");total+=copyFolderContents(root+"\\DROP_GAMES_HERE\\CD-ROM",root+"\\Library\\CD-ROM");total+=importGba();total+=importCdLoose();alert(total?total+" item(s) imported.\n\nOriginal files were not deleted.":"Nothing new was found in DROP_GAMES_HERE.");scan();}
function diagnose(){var d='<h2>System check</h2>';d+='<div class="row">Plugcade folder: <b>'+esc(root)+'</b></div>';d+='<div class="row">DOS emulator: <span class="'+(dosbox()?"ok":"bad")+'">'+(dosbox()?"READY":"MISSING")+'</span></div>';d+='<div class="row">GBA emulator: <span class="'+(gbaemu()?"ok":"bad")+'">'+(gbaemu()?"READY":"MISSING")+'</span></div>';d+='<div class="row">Library: <b>'+games.length+' game(s)</b></div>';document.getElementById("diagnostics").innerHTML=d;}
function showDiag(){var p=document.getElementById("diagnostics");p.className=p.className=="panel hidden"?"panel":"panel hidden";}
function openDrop(){shell.Run("explorer.exe "+q(root+"\\DROP_GAMES_HERE"),1,false);}
function init(){root=pathFromUrl();ensureTree();scan();window.resizeTo(1000,720);}
</script>
</head>
<body onload="init()">
<div class="top"><div class="logo">PLUGCADE</div><div class="tag">YOUR ARCADE. ANYWHERE.</div><div class="status" id="count">LOADING...</div><div class="clear"></div></div>
<div class="hero"><h1>Your games. <b>Your rules.</b></h1><p>Portable. Offline. Built for old computers.</p></div>
<div class="toolbar"><div class="tabs"><button id="tALL" class="tab on" onclick="tab('ALL')">ALL</button><button id="tDOS" class="tab" onclick="tab('DOS')">DOS</button><button id="tGBA" class="tab" onclick="tab('GBA')">GBA</button><button id="tCD" class="tab" onclick="tab('CD')">CD-ROM</button></div><button class="action import" onclick="doImport()">IMPORT GAMES</button><button class="action" onclick="openDrop()">OPEN DROP FOLDER</button><button class="action" onclick="showDiag()">SYSTEM CHECK</button><div class="clear"></div></div>
<div class="search"><input id="find" type="text" onkeyup="render()" placeholder="Find a game..." /></div>
<div id="diagnostics" class="panel hidden"></div><div id="cards" class="content"></div>
<div class="foot">PLUGCADE 0.2 ALPHA · NO INTERNET REQUIRED · USER-SUPPLIED GAMES ONLY</div>
</body></html>
