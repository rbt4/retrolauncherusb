<!DOCTYPE html>
<html>
<head>
<title>Plugcade</title>
<HTA:APPLICATION ID="plugcade" APPLICATIONNAME="Plugcade" VERSION="0.3.0" BORDER="thick" CAPTION="yes" SHOWINTASKBAR="yes" SINGLEINSTANCE="yes" SCROLL="yes" WINDOWSTATE="normal" />
<meta http-equiv="X-UA-Compatible" content="IE=8" />
<style type="text/css">
html,body{margin:0;padding:0;background:#fff4df;color:#211a37;font-family:Verdana,Arial,sans-serif;font-size:13px}button,input,select{font-family:Verdana,Arial,sans-serif}.top{background:#fffaf0;border-bottom:4px solid #211a37;padding:12px 18px;min-height:46px}.logo{float:left;font-family:Courier New,monospace;font-weight:bold;font-size:25px;color:#ff522e;letter-spacing:-2px}.tag{float:left;margin:8px 0 0 14px;font-size:10px;font-weight:bold;letter-spacing:1px}.status{float:right;margin:3px 0 0 8px;background:#dff5e6;border:2px solid #211a37;padding:7px 10px;font-weight:bold}.mode{float:right;background:#ffd13b;border:2px solid #211a37;padding:7px 10px;font-weight:bold;box-shadow:2px 2px 0 #211a37;cursor:pointer}.hero{background:#ff522e;color:#211a37;border-bottom:4px solid #211a37;padding:18px 22px}.hero h1{color:white;font-size:29px;margin:0 0 4px;text-shadow:3px 3px 0 #211a37}.hero b{color:#ffd13b}.hero p{margin:0;font-weight:bold}.kidGuide{display:none;background:#ffd13b;border-bottom:4px solid #211a37;padding:12px 20px;text-align:center;font-size:17px;font-weight:bold}.kidGuide span{display:inline-block;margin:3px 16px}.kidGuide i{display:inline-grid;width:32px;height:32px;line-height:32px;margin-right:6px;background:#fffaf0;border:2px solid #211a37;border-radius:50%;font-style:normal}.toolbar{padding:14px 18px 8px;overflow:hidden}.toolbar select,.action{border:2px solid #211a37;background:#fffaf0;padding:8px 10px;margin:0 7px 6px 0;font-weight:bold;box-shadow:3px 3px 0 #211a37}.action{cursor:pointer}.action.import{background:#38b86d}.action.systems{background:#35aef4}.search{padding:0 18px 10px}.search input{width:96%;border:3px solid #211a37;padding:9px;background:white;font-size:14px}.content{padding:0 14px 30px}.card{display:inline-block;vertical-align:top;width:215px;margin:8px;border:3px solid #211a37;background:#fffaf0;box-shadow:5px 5px 0 #211a37;cursor:pointer}.card.selected{outline:6px solid #ffd13b;outline-offset:2px}.cover{height:115px;border-bottom:3px solid #211a37;overflow:hidden;position:relative;text-align:center}.cover img{width:100%;height:100%;object-fit:cover}.cover .letter{display:block;padding-top:26px;font-family:Courier New,monospace;font-weight:bold;font-size:48px;color:#ffd13b;text-shadow:3px 3px 0 #211a37}.cover .plat{position:absolute;right:5px;top:5px;background:#211a37;color:white;padding:4px;font-size:9px}.info{padding:11px}.info h2{font-size:17px;margin:0 0 3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.info p{color:#746b80;margin:0 0 9px;height:16px}.cardButtons{white-space:nowrap}.play,.say,.help{border:2px solid #211a37;padding:8px;font-weight:bold;cursor:pointer}.play{width:100%;background:#ffd13b}.say,.help{display:none;width:48%;margin-top:6px;background:#35aef4}.help{background:#38b86d}.warning{background:#fff0bd;border:2px solid #211a37;padding:7px;margin-top:8px;font-size:10px}.empty{margin:25px;padding:25px;border:3px dashed #211a37;text-align:center}.empty .big{font-size:62px;color:#ff522e;font-family:Courier New,monospace;font-weight:bold}.panel{margin:12px 20px 25px;padding:17px;border:3px solid #211a37;background:#fffaf0;box-shadow:5px 5px 0 #211a37}.panel h2{margin-top:0}.row{padding:8px 0;border-bottom:1px solid #dfd1b7}.ok{color:#147a42;font-weight:bold}.bad{color:#c43d2f;font-weight:bold}.systemGrid{overflow:hidden}.systemItem{float:left;width:31%;min-height:48px;margin:5px;padding:7px;border:2px solid #211a37;background:#fff4df}.systemItem input{width:20px;height:20px;vertical-align:middle}.systemItem b{display:inline-block;vertical-align:middle}.panelButtons{clear:both;padding-top:13px}.overlay{display:none;position:fixed;left:0;right:0;top:0;bottom:0;background:#211a37;z-index:50}.helpbox{width:68%;max-height:70%;overflow:auto;margin:7% auto;padding:24px;background:#fffaf0;border:5px solid #211a37;box-shadow:10px 10px 0 #ff522e}.helpbox h2{font-size:27px;margin-top:0}.helpText{white-space:pre-wrap;font-size:17px;line-height:1.5}.close{background:#ffd13b;border:3px solid #211a37;padding:10px 18px;font-weight:bold}.foot{background:#211a37;color:white;padding:13px 20px;font-size:10px}.clear{clear:both}.hidden{display:none}.kid .adultOnly{display:none}.kid .kidGuide{display:block}.kid .card{width:260px;margin:13px}.kid .cover{height:165px}.kid .cover .letter{padding-top:46px;font-size:62px}.kid .info h2{font-size:23px;text-align:center}.kid .info p{text-align:center;font-size:12px}.kid .play{font-size:19px;padding:12px}.kid .say,.kid .help{display:inline-block;font-size:14px}.kid .warning{display:none}.kid .content{text-align:center}.kid .empty{font-size:17px}.kid .hero{padding:13px 22px}.kid .hero h1{font-size:24px}
</style>
<script language="JScript">
var fso=new ActiveXObject("Scripting.FileSystemObject"),shell=new ActiveXObject("WScript.Shell");
var root="",current="ALL",kidMode=true,games=[],visibleGames=[],selected=0,enabled="";
function P(id,name,exts,kind,symbol,color,aliases){return{id:id,name:name,exts:exts,kind:kind,symbol:symbol,color:color,aliases:aliases};}
var platforms=[
P("DOS","DOS","","dos","PC","#1677d2","DOSGAMES"),P("CD","DOS CD-ROM","cue,iso","doscd","CD","#6659a7","CDROM,DOSCD"),P("ARCADE","Arcade / MAME","zip","rom","A","#ed5a2a","MAME,ARCADEGAMES"),
P("NES","Nintendo NES","nes,fds","rom","N","#c43d2f","FAMICOM,NINTENDO"),P("SNES","Super Nintendo","sfc,smc","rom","S","#7464ba","SUPERFAMICOM,SUPERNES"),P("N64","Nintendo 64","z64,n64,v64","rom","64","#38b86d","NINTENDO64"),
P("GB","Game Boy","gb","rom","GB","#739b3b","GAMEBOY"),P("GBC","Game Boy Color","gbc","rom","C","#f65b9a","GAMEBOYCOLOR"),P("GBA","Game Boy Advance","gba","rom","G","#6659a7","GAMEBOYADVANCE"),P("VB","Virtual Boy","vb","rom","V","#d8362a","VIRTUALBOY"),
P("GENESIS","Genesis / Mega Drive","md,gen,smd,bin","rom","16","#211a37","MEGADRIVE,SEGA"),P("SMS","Master System","sms","rom","M","#35aef4","MASTERSYSTEM"),P("GAMEGEAR","Game Gear","gg","rom","GG","#1677d2","GEAR"),P("SEGA32X","Sega 32X","32x","rom","32","#211a37","32X"),P("SEGACD","Sega CD","cue,iso","disc","SC","#c43d2f","MEGACD"),
P("PS1","PlayStation 1","cue,iso,chd","disc","PS","#6d6d6d","PLAYSTATION,PSX"),P("PCE","PC Engine / TurboGrafx","pce","rom","P","#ff522e","PCENGINE,TURBOGRAFX,TG16"),
P("ATARI2600","Atari 2600","a26,bin","rom","26","#f1b91d","2600,VCS"),P("ATARI7800","Atari 7800","a78,bin","rom","78","#ed5a2a","7800"),P("LYNX","Atari Lynx","lnx","rom","L","#35aef4","ATARILYNX"),
P("NGP","Neo Geo Pocket","ngp,ngc","rom","NG","#38b86d","NEOGEOPOCKET"),P("WONDERSWAN","WonderSwan","ws,wsc","rom","W","#7464ba","WS"),P("COLECO","ColecoVision","col,rom","rom","C","#1677d2","COLECOVISION"),P("INTELLIVISION","Intellivision","int,bin,rom","rom","I","#ed5a2a","INTV"),P("MSX","MSX","rom,mx1,mx2,dsk","rom","M","#38b86d","MSX1,MSX2"),P("AMIGA","Commodore Amiga","adf,adz,ipf,lha","rom","A","#f65b9a","COMMODOREAMIGA")
];
function esc(s){return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/\"/g,"&quot;");}
function q(s){return '"'+String(s).replace(/"/g,'""')+'"';}
function pathFromUrl(){var p=unescape(location.pathname);if(p.charAt(0)=="/"&&p.charAt(2)==":")p=p.substr(1);return fso.GetParentFolderName(p.replace(/\//g,"\\"));}
function ensure(p){if(!fso.FolderExists(p))fso.CreateFolder(p);}
function ext(n){var i=n.lastIndexOf(".");return i<0?"":n.substr(i+1).toLowerCase();}
function base(n){var i=n.lastIndexOf(".");return i<0?n:n.substr(0,i);}
function safeName(n){return n.replace(/[\\\/:*?\"<>|]/g,"_");}
function norm(n){return String(n).toUpperCase().replace(/[^A-Z0-9]/g,"");}
function platform(id){for(var i=0;i<platforms.length;i++)if(platforms[i].id==id)return platforms[i];return null;}
function contains(csv,v){return(","+csv.toUpperCase()+",").indexOf(","+v.toUpperCase()+",")>=0;}
function enabledPlatform(p){return contains(enabled,p.id);}
function settingsPath(){return root+"\\Config\\settings.ini";}
function readKey(path,key,def){if(!fso.FileExists(path))return def;var t=fso.OpenTextFile(path,1,false),line,k=key.toLowerCase()+"=";while(!t.AtEndOfStream){line=t.ReadLine();if(line.toLowerCase().indexOf(k)==0){t.Close();return line.substr(k.length);}}t.Close();return def;}
function loadSettings(){var p=settingsPath();kidMode=readKey(p,"kidmode","1")!="0";enabled=readKey(p,"platforms","DOS,CD,ARCADE,NES,SNES,N64,GB,GBC,GBA,GENESIS,SMS,GAMEGEAR,PCE,ATARI2600,PS1");}
function saveSettings(){var t=fso.OpenTextFile(settingsPath(),2,true);t.WriteLine("kidmode="+(kidMode?"1":"0"));t.WriteLine("platforms="+enabled);t.Close();}
function writePlatformGuide(){var path=root+"\\Config\\PLATFORMS.txt";if(fso.FileExists(path))return;var t=fso.OpenTextFile(path,2,true);t.WriteLine("PLUGCADE PLATFORM FOLDERS");t.WriteLine("=========================");t.WriteLine("");for(var i=0;i<platforms.length;i++)t.WriteLine(platforms[i].id+" = "+platforms[i].name+" ["+platforms[i].exts+"]");t.WriteLine("");t.WriteLine("Enable or disable systems from Grown-up Mode > Choose systems.");t.Close();}
function ensureTree(){var dirs=["DROP_GAMES_HERE","Library","Emulators","Saves","Backups","Config","Cache","Logs"];for(var i=0;i<dirs.length;i++)ensure(root+"\\"+dirs[i]);for(i=0;i<platforms.length;i++)if(enabledPlatform(platforms[i])){ensure(root+"\\DROP_GAMES_HERE\\"+platforms[i].id);ensure(root+"\\Library\\"+platforms[i].id);ensure(root+"\\Emulators\\"+platforms[i].id);ensure(root+"\\Saves\\"+platforms[i].id);}writePlatformGuide();}
function exts(p){return p.exts?p.exts.split(","):[];}
function accepted(p,file){var z=ext(file.Name),a=exts(p);for(var i=0;i<a.length;i++)if(z==a[i])return true;return false;}
function firstFile(folder,p){var e=new Enumerator(folder.Files);for(;!e.atEnd();e.moveNext()){var x=e.item();if(accepted(p,x))return x.Path;}return "";}
function findDosTarget(folder){var bad=" setup install config uninstall unins patch update register readme help ",best="",count=0,e=new Enumerator(folder.Files);for(;!e.atEnd();e.moveNext()){var x=e.item(),z=ext(x.Name),n=" "+base(x.Name).toLowerCase()+" ";if((z=="exe"||z=="com"||z=="bat")&&bad.indexOf(n)<0){if(!best)best=x.Name;count++;}}return count==1?best:"";}
function readRun(folder){var ini=folder.Path+"\\game.ini",r=readKey(ini,"run","");return r?r:findDosTarget(folder);}
function coverFor(dir){var n=["cover.jpg","cover.png","cover.gif","cover.bmp"];for(var i=0;i<n.length;i++)if(fso.FileExists(dir+"\\"+n[i]))return dir+"\\"+n[i];return "";}
function fileUrl(p){return encodeURI("file:///"+p.replace(/\\/g,"/"));}
function addGame(p,title,path,target,dir){games[games.length]={platform:p.id,title:title,path:path,target:target,dir:dir,cover:coverFor(dir)};}
function scanPlatform(p){var path=root+"\\Library\\"+p.id;if(!fso.FolderExists(path))return;var folder=fso.GetFolder(path),e=new Enumerator(folder.SubFolders);for(;!e.atEnd();e.moveNext()){var d=e.item();if(p.kind=="dos")addGame(p,d.Name,d.Path,readRun(d),d.Path);else{var r=firstFile(d,p);if(r)addGame(p,d.Name,r,p.kind=="doscd"?readRun(d):"",d.Path);}}e=new Enumerator(folder.Files);for(;!e.atEnd();e.moveNext()){var x=e.item();if(accepted(p,x))addGame(p,base(x.Name),x.Path,"",folder.Path);}}
function scan(){games=[];for(var i=0;i<platforms.length;i++)if(enabledPlatform(platforms[i]))scanPlatform(platforms[i]);games.sort(function(a,b){var x=a.title.toLowerCase(),y=b.title.toLowerCase();return x<y?-1:x>y?1:0;});buildFilter();render();diagnose();}
function buildFilter(){var s=document.getElementById("platformFilter"),h='<option value="ALL">ALL SYSTEMS</option>';for(var i=0;i<platforms.length;i++)if(enabledPlatform(platforms[i]))h+='<option value="'+platforms[i].id+'">'+esc(platforms[i].name)+'</option>';s.innerHTML=h;s.value=current;}
function cancelClick(){if(window.event)window.event.cancelBubble=true;}
function render(){var h="",term=kidMode?"":document.getElementById("find").value.toLowerCase();visibleGames=[];for(var i=0;i<games.length;i++){var g=games[i],p=platform(g.platform);if(!kidMode&&current!="ALL"&&current!=g.platform)continue;if(term&&g.title.toLowerCase().indexOf(term)<0)continue;visibleGames[visibleGames.length]=i;var warn=emulatorFor(p).exe?"":'<div class="warning">Grown-up setup needed: add an emulator</div>';var cover=g.cover?'<img src="'+esc(fileUrl(g.cover))+'" alt="" />':'<span class="letter">'+esc(p.symbol)+'</span>';h+='<div id="card'+i+'" class="card" onclick="play('+i+')"><div class="cover" style="background:'+p.color+'"><span class="plat">'+esc(p.id)+'</span>'+cover+'</div><div class="info"><h2>'+esc(g.title)+'</h2><p>'+esc(p.name)+'</p><div class="cardButtons"><button class="play" onclick="cancelClick();play('+i+')">PLAY</button><button class="say" title="Say game name" onclick="cancelClick();speakGame('+i+')">SAY</button> <button class="help" title="Open help card" onclick="cancelClick();helpGame('+i+')">HELP</button></div>'+warn+'</div></div>';}if(!h)h='<div class="empty"><div class="big">P</div><h2>No games are ready yet</h2><p>Ask a grown-up to add games. Grown-ups: switch modes, open the drop folder, then import.</p></div>';document.getElementById("cards").innerHTML=h;document.getElementById("count").innerText=games.length+" READY";if(selected>=visibleGames.length)selected=0;paintSelected();}
function changeFilter(){current=document.getElementById("platformFilter").value;render();}
function paintSelected(){for(var i=0;i<visibleGames.length;i++){var c=document.getElementById("card"+visibleGames[i]);if(c)c.className="card"+(i==selected?" selected":"");}}
function keyNav(){if(!kidMode||!visibleGames.length)return;var e=window.event,k=e.keyCode;if(k==37||k==38){selected--;if(selected<0)selected=visibleGames.length-1;paintSelected();e.returnValue=false;}else if(k==39||k==40){selected++;if(selected>=visibleGames.length)selected=0;paintSelected();e.returnValue=false;}else if(k==13){play(visibleGames[selected]);e.returnValue=false;}else if(k==32){speakGame(visibleGames[selected]);e.returnValue=false;}else if(k==72){helpGame(visibleGames[selected]);e.returnValue=false;}}
function speak(text){try{var v=new ActiveXObject("SAPI.SpVoice");v.Speak(text,1);return true;}catch(e){return false;}}
function speakGame(i){var g=games[i],p=platform(g.platform);if(!speak("Play "+g.title+". "+p.name+"."))alert(g.title+"\n"+p.name+"\n\nSpeech is not installed on this Windows computer.");}
function helpGame(i){var g=games[i],path=g.dir+"\\help.txt",text="No help card has been added for this game yet. Ask a grown-up for help.";if(fso.FileExists(path)){var t=fso.OpenTextFile(path,1,false);text=t.ReadAll();t.Close();}document.getElementById("helpTitle").innerText=g.title+" - Help";document.getElementById("helpText").innerText=text;document.getElementById("overlay").style.display="block";speak(text.substr(0,700));}
function closeHelp(){document.getElementById("overlay").style.display="none";}
function emulatorFor(p){var dir=root+"\\Emulators\\"+p.id,ini=dir+"\\emulator.ini",run=readKey(ini,"run",""),args=readKey(ini,"args",'"%ROM%"'),exe="";if(run&&fso.FileExists(dir+"\\"+run))exe=dir+"\\"+run;if(!exe&&fso.FolderExists(dir)){var e=new Enumerator(fso.GetFolder(dir).Files);for(;!e.atEnd();e.moveNext()){var x=e.item();if(ext(x.Name)=="exe"){exe=x.Path;break;}}}return{exe:exe,args:args};}
function dosbox(){var d=root+"\\Emulators\\DOS\\",a=[d+"dosbox-x.exe",d+"dosbox.exe"];for(var i=0;i<a.length;i++)if(fso.FileExists(a[i]))return a[i];var e=emulatorFor(platform("DOS"));return e.exe;}
function pickDosTarget(g){var d=fso.GetFolder(g.dir),v=window.prompt("Enter the exact DOS program to start (example: GAME.EXE)","");if(!v)return "";if(!fso.FileExists(d.Path+"\\"+v)){alert("That file was not found in:\n"+d.Path);return "";}var t=fso.OpenTextFile(d.Path+"\\game.ini",2,true);t.WriteLine("run="+v);t.Close();g.target=v;return v;}
function token(s,key,value){while(s.indexOf(key)>=0)s=s.replace(key,value);return s;}
function play(i){var g=games[i],p=platform(g.platform),emu,conf,t,dir,info,args;if(p.kind=="dos"||p.kind=="doscd"){emu=dosbox();if(!emu){speak("Ask a grown-up to set up the DOS player.");alert("DOS emulator missing.\n\nGrown-up: place dosbox-x.exe or dosbox.exe in:\n"+root+"\\Emulators\\DOS");return;}if(!g.target&&!pickDosTarget(g))return;conf=root+"\\Cache\\launch.conf";t=fso.OpenTextFile(conf,2,true);t.WriteLine("[sdl]");t.WriteLine("fullscreen=true");t.WriteLine("[autoexec]");if(p.kind=="dos"){dir=g.path;t.WriteLine('mount c "'+dir+'"');t.WriteLine("c:");t.WriteLine('call "'+g.target+'"');}else{dir=fso.GetParentFolderName(g.path);t.WriteLine('mount c "'+dir+'"');t.WriteLine('imgmount d "'+g.path+'" -t iso');t.WriteLine("d:");t.WriteLine('call "'+g.target+'"');}t.WriteLine("exit");t.Close();shell.Run(q(emu)+" -conf "+q(conf)+" -exit",1,false);return;}info=emulatorFor(p);if(!info.exe){speak("Ask a grown-up to set up the "+p.name+" player.");alert("No "+p.name+" emulator is configured.\n\nPlace a compatible portable emulator EXE in:\n"+root+"\\Emulators\\"+p.id+"\n\nOptional: add emulator.ini to specify run= and args=.");return;}args=token(info.args,"%ROM%",g.path);args=token(args,"%ROOT%",root);args=token(args,"%SAVES%",root+"\\Saves\\"+p.id);shell.Run(q(info.exe)+" "+args,1,false);}
function copyFolders(src,dst){if(!fso.FolderExists(src))return 0;var count=0,e=new Enumerator(fso.GetFolder(src).SubFolders);for(;!e.atEnd();e.moveNext()){var d=e.item(),to=dst+"\\"+safeName(d.Name);if(fso.FolderExists(to)){if(!confirm(d.Name+" is already imported. Replace Plugcade's copy?"))continue;fso.DeleteFolder(to,true);}fso.CopyFolder(d.Path,to,true);count++;}return count;}
function copyLoose(src,dst,p){if(!fso.FolderExists(src))return 0;var count=0,e=new Enumerator(fso.GetFolder(src).Files);for(;!e.atEnd();e.moveNext()){var x=e.item();if(!accepted(p,x))continue;if((p.kind=="disc"||p.kind=="doscd")&&ext(x.Name)!="iso"&&ext(x.Name)!="chd")continue;var d=dst+"\\"+safeName(base(x.Name));ensure(d);var to=d+"\\"+x.Name;if(!fso.FileExists(to)||confirm(x.Name+" is already imported. Replace Plugcade's copy?")){fso.CopyFile(x.Path,to,true);count++;}}return count;}
function importSource(src,p){var dst=root+"\\Library\\"+p.id;return copyFolders(src,dst)+copyLoose(src,dst,p);}
function doImport(){var total=0;for(var i=0;i<platforms.length;i++)if(enabledPlatform(platforms[i]))total+=importSource(root+"\\DROP_GAMES_HERE\\"+platforms[i].id,platforms[i]);alert(total?total+" item(s) imported.\n\nOriginal files were not deleted.":"Nothing new was found in the enabled DROP_GAMES_HERE folders.");scan();}
function matchFolder(name){var n=norm(name);for(var i=0;i<platforms.length;i++){var p=platforms[i];if(n==norm(p.id)||n==norm(p.name)||contains(p.aliases,n))return p;}return null;}
function addCollection(){var app=new ActiveXObject("Shell.Application"),picked=app.BrowseForFolder(0,"Choose a collection folder. Plugcade looks for system folders such as NES, SNES, GBA or PS1.",0,0);if(!picked)return;var path=picked.Self.Path,p=matchFolder(fso.GetFolder(path).Name),total=0,matched=0;if(p){if(!enabledPlatform(p)){enabled+=(enabled?",":"")+p.id;saveSettings();ensureTree();}total+=importSource(path,p);matched++;}else{var e=new Enumerator(fso.GetFolder(path).SubFolders);for(;!e.atEnd();e.moveNext()){var d=e.item();p=matchFolder(d.Name);if(p){if(!enabledPlatform(p)){enabled+=(enabled?",":"")+p.id;saveSettings();ensureTree();}total+=importSource(d.Path,p);matched++;}}}if(!matched)alert("No recognizable system folders were found.\n\nTry folders named NES, SNES, GBA, GENESIS, PS1, ARCADE, and so on.");else alert(total+" item(s) imported from "+matched+" system folder(s).\n\nOriginal files were not deleted.");scan();}
function diagnose(){var d='<h2>System check</h2><div class="row">Plugcade folder: <b>'+esc(root)+'</b></div><div class="row">Mode: <b>'+(kidMode?"KID":"GROWN-UP")+'</b></div>';for(var i=0;i<platforms.length;i++)if(enabledPlatform(platforms[i])){var p=platforms[i],ready=(p.kind=="dos"||p.kind=="doscd")?dosbox():emulatorFor(p).exe;d+='<div class="row">'+esc(p.name)+': <span class="'+(ready?"ok":"bad")+'">'+(ready?"READY":"EMULATOR NEEDED")+'</span></div>';}document.getElementById("diagnostics").innerHTML=d;}
function togglePanel(id){var p=document.getElementById(id);p.className=p.className.indexOf("hidden")>=0?p.className.replace(" hidden",""):p.className+" hidden";}
function showSystems(){var h='<h2>Choose systems</h2><p>Enable only what this computer or USB needs. You can change this any time.</p><div class="systemGrid">';for(var i=0;i<platforms.length;i++){var p=platforms[i];h+='<label class="systemItem"><input type="checkbox" id="sys'+p.id+'" '+(enabledPlatform(p)?'checked="checked"':'')+' /> <b>'+esc(p.name)+'</b><br /><small>.'+esc(p.exts.replace(/,/g,", ."))+'</small></label>';}h+='</div><div class="panelButtons"><button class="action" onclick="systemPreset(\'classic\')">CLASSIC PICKS</button><button class="action" onclick="systemPreset(\'all\')">ENABLE ALL</button><button class="action import" onclick="saveSystems()">SAVE SYSTEMS</button></div>';document.getElementById("systemsPanel").innerHTML=h;document.getElementById("systemsPanel").className="panel";}
function systemPreset(which){var classic="DOS,CD,ARCADE,NES,SNES,N64,GB,GBC,GBA,GENESIS,SMS,GAMEGEAR,PCE,ATARI2600,PS1";for(var i=0;i<platforms.length;i++)document.getElementById("sys"+platforms[i].id).checked=which=="all"||contains(classic,platforms[i].id);}
function saveSystems(){var s="";for(var i=0;i<platforms.length;i++)if(document.getElementById("sys"+platforms[i].id).checked)s+=(s?",":"")+platforms[i].id;if(!s){alert("Choose at least one system.");return;}enabled=s;saveSettings();ensureTree();document.getElementById("systemsPanel").className="panel hidden";scan();}
function toggleMode(){kidMode=!kidMode;saveSettings();applyMode();render();diagnose();}
function applyMode(){document.body.className=kidMode?"kid":"grown";document.getElementById("modeButton").innerText=kidMode?"GROWN-UP MODE":"KID MODE";if(kidMode){current="ALL";document.getElementById("find").value="";}}
function openDrop(){shell.Run("explorer.exe "+q(root+"\\DROP_GAMES_HERE"),1,false);}
function init(){root=pathFromUrl();ensure(root+"\\Config");loadSettings();ensureTree();applyMode();scan();document.onkeydown=keyNav;window.resizeTo(1100,760);if(kidMode&&games.length)speak("Plugcade is ready. Use the arrow keys to choose a game. Press enter to play.");}
</script>
</head>
<body onload="init()">
<div class="top"><div class="logo">PLUGCADE</div><div class="tag">YOUR ARCADE. ANYWHERE.</div><div class="status" id="count">LOADING...</div><button id="modeButton" class="mode" onclick="toggleMode()">GROWN-UP MODE</button><div class="clear"></div></div>
<div class="hero"><h1>Your games. <b>Your rules.</b></h1><p>Portable. Offline. Friendly for kids. Configurable by grown-ups.</p></div>
<div class="kidGuide"><span><i>&larr;&rarr;</i> CHOOSE</span><span><i>&crarr;</i> PLAY</span><span><i>H</i> HELP</span><span><i>_</i> SAY NAME</span></div>
<div class="toolbar adultOnly"><select id="platformFilter" onchange="changeFilter()"><option value="ALL">ALL SYSTEMS</option></select><button class="action import" onclick="doImport()">IMPORT DROP FOLDERS</button><button class="action" onclick="addCollection()">ADD EXISTING COLLECTION</button><button class="action" onclick="openDrop()">OPEN DROP FOLDER</button><button class="action systems" onclick="showSystems()">CHOOSE SYSTEMS</button><button class="action" onclick="togglePanel('diagnostics')">SYSTEM CHECK</button></div>
<div class="search adultOnly"><input id="find" type="text" onkeyup="render()" placeholder="Find a game..." /></div>
<div id="systemsPanel" class="panel hidden adultOnly"></div><div id="diagnostics" class="panel hidden adultOnly"></div><div id="cards" class="content"></div>
<div id="overlay" class="overlay"><div class="helpbox"><h2 id="helpTitle">Game help</h2><div id="helpText" class="helpText"></div><p><button class="close" onclick="closeHelp()">BACK TO GAMES</button></p></div></div>
<div class="foot">PLUGCADE 0.3 ALPHA · KID MODE DEFAULT · NO INTERNET REQUIRED · USER-SUPPLIED GAMES ONLY</div>
</body></html>
